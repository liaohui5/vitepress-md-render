{
  "name": "vitepress-md-render",
  "version": "1.0.0",
  "description": "markdown render compatible to vitepress",
  "keywords": [
    "markdown-render",
    "vitepress"
  ],
  "license": "MIT",
  "author": "liaohui5 <secretx500@gmail.com>",
  "files": [
    "./dist"
  ],
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.cts",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown && vite . --port 3000",
    "release": "semantic-release --debug"
  },
  "dependencies": {
    "@mdit-vue/plugin-component": "^3.0.2",
    "@mdit-vue/plugin-frontmatter": "^3.0.2",
    "@mdit-vue/plugin-headers": "^3.0.2",
    "@mdit-vue/plugin-sfc": "^3.0.2",
    "@mdit-vue/plugin-title": "^3.0.2",
    "@mdit-vue/plugin-toc": "^3.0.2",
    "@mdit-vue/shared": "^3.0.2",
    "@shikijs/core": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-async": "^2.2.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-cjk-friendly": "^2.0.2",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-todo-lists": "^0.1.8",
    "nanoid": "^5.1.11",
    "picocolors": "^1.1.1",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@shikijs/types": "^4.0.2",
    "@tsdown/css": "^0.22.3",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-attrs": "^4.1.3",
    "@types/markdown-it-container": "^4.0.0",
    "@types/markdown-it-emoji": "^3.0.1",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "4.0.0-beta.4"
  }
}
